{
  "expectation_suite_name": "acidentes_suite",
  "expectations": [
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": { "column": "data" }
    },
    {
      "expectation_type": "expect_column_values_to_be_between",
      "kwargs": { "column": "km", "min_value": 0, "max_value": 1000 }
    },
    {
      "expectation_type": "expect_column_values_to_be_between",
      "kwargs": { "column": "latitude", "min_value": -90, "max_value": 90 }
    },
    {
      "expectation_type": "expect_column_values_to_be_between",
      "kwargs": { "column": "hora", "min_value": 0, "max_value": 23 }
    },
    {
      "expectation_type": "expect_column_values_to_be_in_set",
      "kwargs": {
        "column": "sentido",
        "value_set": ["NORTE", "SUL", "LESTE", "OESTE", "EXTERNO", "INTERNO"]
      }
    }
  ]
}